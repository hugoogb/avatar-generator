{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "composite": true,
        "declarationDir": "./dist/types",
        "outDir": "./dist",
        "rootDir": "src"
    },
    "include": ["src"]
}
